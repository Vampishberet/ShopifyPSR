<section class="pulsar-videos">
  <div class="pulsar-videos__inner">
    <div class="pulsar-videos__header">
      <p class="pulsar-videos__overline pulsar-reveal">{{ section.settings.overline | default: 'Content' }}</p>
      <h2 class="pulsar-videos__heading pulsar-heading-reveal">{{ section.settings.heading | default: 'WATCH' }}</h2>
    </div>

    <div class="pulsar-videos__grid pulsar-stagger-group">
      {%- assign video_1_base = section.settings.video_1_url | default: 'https://www.youtube.com/embed/MoZfg__UPRo' -%}
      {%- assign video_2_base = section.settings.video_2_url | default: 'https://www.youtube.com/embed/3Po08NzKqlc' -%}

      <!-- Fortnite montage -->
      <div class="pulsar-videos__item pulsar-stagger-item">
        <div class="pulsar-videos__frame-outer">
          <div class="pulsar-videos__embed-wrap" data-pulsar-video-wrap>
            <iframe
              data-pulsar-video-src="{{ video_1_base }}?rel=0&modestbranding=1&enablejsapi=1"
              src="{{ video_1_base }}?rel=0&modestbranding=1&enablejsapi=1"
              title="{{ section.settings.video_1_title | default: 'Pulsar Fortnite Montage' }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
          <div class="pulsar-videos__frame-corner pulsar-videos__frame-corner--tl" aria-hidden="true"></div>
          <div class="pulsar-videos__frame-corner pulsar-videos__frame-corner--tr" aria-hidden="true"></div>
          <div class="pulsar-videos__frame-corner pulsar-videos__frame-corner--bl" aria-hidden="true"></div>
          <div class="pulsar-videos__frame-corner pulsar-videos__frame-corner--br" aria-hidden="true"></div>
        </div>
        <div class="pulsar-videos__item-meta">
          <span class="pulsar-videos__item-tag">{{ section.settings.video_1_tag | default: 'Fortnite' }}</span>
          <p class="pulsar-videos__item-title">{{ section.settings.video_1_title | default: 'Pulsar Fortnite Montage' }}</p>
        </div>
      </div>

      <!-- Valorant montage -->
      <div class="pulsar-videos__item pulsar-stagger-item">
        <div class="pulsar-videos__frame-outer">
          <div class="pulsar-videos__embed-wrap" data-pulsar-video-wrap>
            <iframe
              data-pulsar-video-src="{{ video_2_base }}?rel=0&modestbranding=1&enablejsapi=1"
              src="{{ video_2_base }}?rel=0&modestbranding=1&enablejsapi=1"
              title="{{ section.settings.video_2_title | default: 'Pulsar Valorant Montage' }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
          <div class="pulsar-videos__frame-corner pulsar-videos__frame-corner--tl" aria-hidden="true"></div>
          <div class="pulsar-videos__frame-corner pulsar-videos__frame-corner--tr" aria-hidden="true"></div>
          <div class="pulsar-videos__frame-corner pulsar-videos__frame-corner--bl" aria-hidden="true"></div>
          <div class="pulsar-videos__frame-corner pulsar-videos__frame-corner--br" aria-hidden="true"></div>
        </div>
        <div class="pulsar-videos__item-meta">
          <span class="pulsar-videos__item-tag">{{ section.settings.video_2_tag | default: 'Valorant' }}</span>
          <p class="pulsar-videos__item-title">{{ section.settings.video_2_title | default: 'Pulsar Valorant Montage' }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .pulsar-videos {
    background-color: var(--pulsar-dark2);
    padding: var(--pulsar-space-xxl) 0;
  }
  .pulsar-videos__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--pulsar-space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-xl);
  }
  .pulsar-videos__overline {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    margin: 0 0 var(--pulsar-space-sm);
  }
  .pulsar-videos__heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
  }

  .pulsar-videos__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--pulsar-space-lg);
  }
  .pulsar-videos__item {
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-md);
  }
  /* Premium video frame */
  .pulsar-videos__frame-outer {
    position: relative;
  }
  .pulsar-videos__embed-wrap {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 — exact same ratio forces identical sizes */
    height: 0;
    overflow: hidden;
    background-color: var(--pulsar-black);
    border: 1px solid var(--pulsar-dark3);
    box-shadow:
      0 0 0 1px var(--pulsar-dark3),
      0 32px 80px rgba(0, 0, 0, 0.7),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    transition: box-shadow 0.4s var(--pulsar-ease-out);
  }
  .pulsar-videos__frame-outer:hover .pulsar-videos__embed-wrap {
    box-shadow:
      0 0 0 1px var(--pulsar-gray1),
      0 40px 100px rgba(0, 0, 0, 0.8),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }
  .pulsar-videos__embed-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* Corner accent marks */
  .pulsar-videos__frame-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    z-index: 2;
    pointer-events: none;
  }
  .pulsar-videos__frame-corner--tl { top: -1px; left: -1px; border-top: 2px solid var(--pulsar-gray1); border-left: 2px solid var(--pulsar-gray1); }
  .pulsar-videos__frame-corner--tr { top: -1px; right: -1px; border-top: 2px solid var(--pulsar-gray1); border-right: 2px solid var(--pulsar-gray1); }
  .pulsar-videos__frame-corner--bl { bottom: -1px; left: -1px; border-bottom: 2px solid var(--pulsar-gray1); border-left: 2px solid var(--pulsar-gray1); }
  .pulsar-videos__frame-corner--br { bottom: -1px; right: -1px; border-bottom: 2px solid var(--pulsar-gray1); border-right: 2px solid var(--pulsar-gray1); }
  .pulsar-videos__item-meta {
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-xs);
  }
  .pulsar-videos__item-tag {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
  }
  .pulsar-videos__item-title {
    font-family: var(--font-secondary);
    font-size: 1rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
  }

  @media (max-width: 767px) {
    .pulsar-videos { padding: var(--pulsar-space-xl) 0; }
    .pulsar-videos__inner { padding: 0 var(--pulsar-space-md); gap: var(--pulsar-space-lg); }
    .pulsar-videos__grid { grid-template-columns: 1fr; }
  }
{% endstylesheet %}

