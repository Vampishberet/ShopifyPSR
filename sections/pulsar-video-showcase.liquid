    },
    {
      "type": "header",
      "content": "Video 2"
    },
    {
      "type": "text",
      "id": "video_2_url",
      "label": "YouTube embed URL",
      "default": "https://www.youtube.com/embed/3Po08NzKqlc"
    },
    {
      "type": "text",
      "id": "video_2_title",
      "label": "Video title",
      "default": "Pulsar Valorant Montage"
    },
    {
      "type": "text",
      "id": "video_2_tag",
      "label": "Game tag",
      "default": "Valorant"
    }
