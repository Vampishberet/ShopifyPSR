{%- comment -%}
  Pulsar Member Ribbon
  Depends on assets/marquee.js (custom element: marquee-component).
  marquee.js reads data-speed-factor and sets --marquee-speed on the element at runtime.
{%- endcomment -%}

<script
  src="{{ 'marquee.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign member_names = section.settings.member_names | strip
  assign members = member_names | split: ','
  assign gap_between_elements = section.settings.gap_between_elements
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  id="pulsar-member-ribbon-{{ section.id }}"
  class="pulsar-member-ribbon color-{{ section.settings.color_scheme }}"
>
  {%- if section.settings.heading != blank -%}
    <p class="pulsar-member-ribbon__heading">{{ section.settings.heading }}</p>
  {%- endif -%}

  <marquee-component
    class="pulsar-member-ribbon__marquee section spacing-style gap-style pulsar-reveal"
    style="
      {%- render 'spacing-style', settings: section.settings %};
      {% render 'gap-style', value: gap_between_elements, name: 'marquee-gap' %}
      --marquee-direction: {{ section.settings.movement_direction }};
    "
    data-speed-factor="{{ section.settings.speed_factor }}"
    data-movement-direction="{{ section.settings.movement_direction }}"
    {% if section.settings.pause_on_hover %}
      data-pause-on-hover="true"
    {% endif %}
  >
    <div
      class="marquee__wrapper"
      ref="wrapper"
    >
      <div
        class="marquee__content"
        ref="content"
      >
        {%- for i in (1..2) -%}
          <div
            class="marquee__repeated-items pulsar-member-ribbon__items"
            ref="marqueeItems[]"
            {% if i == 2 %}aria-hidden="true"{% endif %}
          >
            {%- for member in members -%}
              {%- assign name = member | strip -%}
              {%- if name != blank -%}
                <span class="pulsar-member-ribbon__item">
                  <span class="pulsar-member-ribbon__name">{{ name }}</span>
                </span>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </marquee-component>
</section>

{% stylesheet %}
  marquee-component {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .marquee__wrapper {
    display: flex;
    gap: var(--marquee-gap);
    width: fit-content;
    white-space: nowrap;
    will-change: transform;
  }

  .marquee__content {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
  }

  .marquee__repeated-items {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
    align-items: center;
    justify-content: center;
  }

  .marquee__repeated-items > * {
    align-content: center;
  }

  #pulsar-member-ribbon-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background: var(--pulsar-black);
    border-top: 1px solid var(--pulsar-accent-purple-soft);
    border-bottom: 1px solid var(--pulsar-accent-purple-soft);
  }

  #pulsar-member-ribbon-{{ section.id }} .pulsar-member-ribbon__heading {
    margin: 0 0 16px;
    text-align: center;
    font-size: 0.65rem;
    font-family: var(--font-body);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
  }

  #pulsar-member-ribbon-{{ section.id }} .pulsar-member-ribbon__marquee {
    position: relative;
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  #pulsar-member-ribbon-{{ section.id }} .pulsar-member-ribbon__items {
    align-items: center;
  }

  #pulsar-member-ribbon-{{ section.id }} .pulsar-member-ribbon__item {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    white-space: nowrap;
  }

  #pulsar-member-ribbon-{{ section.id }} .pulsar-member-ribbon__name {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    font-family: var(--font-secondary);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pulsar-gray3);
  }

  #pulsar-member-ribbon-{{ section.id }} .pulsar-member-ribbon__name::after {
    content: "✦";
    margin-left: var(--marquee-gap);
    color: var(--pulsar-white);
    font-size: 0.6rem;
    line-height: 1;
  }

  {% if section.settings.pause_on_hover %}
    #pulsar-member-ribbon-{{ section.id }} marquee-component:hover .marquee__wrapper {
      animation-play-state: paused;
    }
  {% endif %}

  @media screen and (max-width: 767px) {
    #pulsar-member-ribbon-{{ section.id }} .pulsar-member-ribbon__heading {
      margin-bottom: 14px;
      font-size: 0.6rem;
    }

    #pulsar-member-ribbon-{{ section.id }} .pulsar-member-ribbon__name {
      font-size: 20px;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    marquee-component:not([data-disabled]) .marquee__wrapper {
      animation: marquee-motion var(--marquee-speed) linear infinite var(--marquee-direction);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    marquee-component .marquee__wrapper {
      animation: none !important;
      transform: none !important;
    }
  }

  @keyframes marquee-motion {
    to {
      transform: translate3d(calc(-50% - (var(--marquee-gap) / 2)), 0, 0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pulsar Member Ribbon",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section label",
      "default": "The people that make it happen"
    },
    {
      "type": "textarea",
      "id": "member_names",
      "label": "Member names",
      "info": "Comma-separated list of member names.",
      "default": "PSR Waffle,PSR Vienna,PSR Chimp,PSR Psych,PSR Rev,PSR Dag,PSR Guppy,PSR Blazify,PSR Casper,PSR Cafe,PSR Acsidius,PSR Yum,PSR Nodaz,PSR Light,PSR Zire,PSR Moxi,PSR Ruin,PSR Staryu,PSR Tuhronto,PSR Hapa,PSR Midniii,PSR Channce,PSR Murlo,PSR Rkei,PSR Molly,PSR GazingNicole,PSR Magnus,PSR Ian,PSR Mika,PSR Njuu,PSR Thunder,PSR CeceNuggets,PSR Kaz,PSR Devox,PSR Klamran,PSR Priince,PSR Ryiax,PSR Gards,PSR Sjay,PSR Adrenaleen,PSR Jid,PSR h6rmed,PSR EXR,PSR Korea,PSR Josh,PSR Prioxy,PSR Fancy,PSR Indra,PSR Mei,PSR Volty,PSR Aminz,PSR Rina,PSR Recrim,PSR Teasers,PSR Vampish,PSR Sieon,PSR Mikey,PSR Ache,PSR iGOMA,PSR Gary,PSR Lunar,PSR Twunti,PSR Thibaut,PSR Monster"
    },
    {
      "type": "select",
      "id": "movement_direction",
      "label": "Movement direction",
      "options": [
        {
          "value": "reverse",
          "label": "Left to right"
        },
        {
          "value": "normal",
          "label": "Right to left"
        }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "speed_factor",
      "label": "Ticker speed",
      "min": 5,
      "max": 60,
      "step": 1,
      "default": 25,
      "info": "Lower usually feels faster in JS-driven marquee systems like this one, depending on how marquee.js is written."
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_between_elements",
      "label": "Gap between names",
      "min": 8,
      "max": 64,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Pulsar Member Ribbon"
    }
  ]
}
{% endschema %}