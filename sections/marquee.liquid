{%- comment -%}
  Pulsar Member Ribbon
  Built directly on the working marquee section structure.
  Depends on assets/marquee.js (custom element: marquee-component).
{%- endcomment -%}

<script
  src="{{ 'marquee.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- liquid
  assign gap_between_elements = section.settings.gap_between_elements
  assign member_names = section.settings.member_names | strip
  assign members = member_names | split: ','
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section class="pulsar-member-ribbon color-{{ section.settings.color_scheme }}">
  {%- if section.settings.heading != blank -%}
    <p class="pulsar-member-ribbon__heading">{{ section.settings.heading }}</p>
  {%- endif -%}

  <marquee-component
    class="section spacing-style gap-style pulsar-reveal"
    style="
      --marquee-gap: {{ gap_between_elements }}px;
      --marquee-direction: {{ section.settings.movement_direction }};
      padding-top: {{ section.settings.padding_block_start }}px;
      padding-bottom: {{ section.settings.padding_block_end }}px;
    "
    data-speed-factor="{{ section.settings.speed_factor }}"
    data-movement-direction="{{ section.settings.movement_direction }}"
  >
    <div
      class="marquee__wrapper"
      ref="wrapper"
    >
      <div
        class="marquee__content"
        ref="content"
      >
        <div
          class="marquee__repeated-items pulsar-member-ribbon__items"
          ref="marqueeItems[]"
        >
          {%- for member in members -%}
            {%- assign name = member | strip -%}
            {%- if name != blank -%}
              <span class="pulsar-member-ribbon__item">
                {{ name }}
              </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </marquee-component>
</section>

{% stylesheet %}
  .pulsar-member-ribbon {
    background: #000;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    overflow: hidden;
  }

  .pulsar-member-ribbon__heading {
    margin: 0 0 16px;
    text-align: center;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground), 0.65);
  }

  marquee-component {
    display: block;
    width: 100%;
    overflow: hidden;
  }

  .marquee__wrapper {
    display: flex;
    gap: var(--marquee-gap);
    width: fit-content;
    white-space: nowrap;
  }

  .marquee__content {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
  }

  .marquee__repeated-items {
    min-width: max-content;
    display: flex;
    gap: var(--marquee-gap);
    align-items: center;
    justify-content: center;
  }

  .pulsar-member-ribbon__item {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    font-size: 1.25rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(var(--color-foreground));
  }

  .pulsar-member-ribbon__item::after {
    content: "✦";
    margin-left: var(--marquee-gap);
    font-size: 0.6rem;
    line-height: 1;
    color: rgb(var(--color-foreground));
  }

  @media screen and (max-width: 767px) {
    .pulsar-member-ribbon__item {
      font-size: 20px;
    }

    .pulsar-member-ribbon__heading {
      margin-bottom: 14px;
      font-size: 0.6rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    marquee-component:not([data-disabled]) .marquee__wrapper {
      animation: marquee-motion var(--marquee-speed) linear infinite var(--marquee-direction);
    }
  }

  @keyframes marquee-motion {
    to {
      transform: translate3d(calc(-50% - (var(--marquee-gap) / 2)), 0, 0);
    }
  }
{% endstylesheet %}

{% schema %}
