<section
  class="pulsar-hero"
  aria-label="Hero"
  id="pulsar-hero-{{ section.id }}"
>
  <div class="pulsar-hero__bg" aria-hidden="true" data-pulsar-parallax data-pulsar-parallax-strength="22">
    {%- if section.settings.bg_video != blank -%}
      <video
        class="pulsar-hero__bg-video"
        src="{{ section.settings.bg_video }}"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      ></video>
    {%- else -%}
      <video
        class="pulsar-hero__bg-video"
        src="{{ '3d animation for preloader.mp4' | asset_url }}"
        autoplay
        muted
        loop
        playsinline
        aria-hidden="true"
      ></video>
    {%- endif -%}
    <div class="pulsar-hero__overlay" aria-hidden="true"></div>
  </div>

  <div class="pulsar-hero__content">
    {%- comment -%} Slides container — single default slide or schema blocks {%- endcomment -%}
    <div
      class="pulsar-hero__slides"
      data-slide-interval="{{ section.settings.slide_interval | default: 5000 }}"
    >
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div
            class="pulsar-hero__slide{% if forloop.first %} is-active{% endif %}"
            role="group"
            aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}"
            {%- unless forloop.first %}
              aria-hidden="true"
            {% endunless %}
            {{ block.shopify_attributes }}
          >
            <p class="pulsar-hero__eyebrow">
              {{ block.settings.eyebrow | default: 'EST. 2020 · NORTH AMERICA' }}
            </p>
            <h1 class="pulsar-hero__heading">
              {{ block.settings.heading | default: 'TEAM PULSAR' }}
            </h1>
            <p class="pulsar-hero__tagline">
              {{ block.settings.tagline | default: 'Move With Intent.' }}
            </p>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Fallback: single slide from section settings {%- endcomment -%}
        <div class="pulsar-hero__slide is-active" role="group" aria-label="Hero">
          <p class="pulsar-hero__eyebrow">
            {{ section.settings.eyebrow | default: 'EST. 2020 · NORTH AMERICA' }}
          </p>
          <h1 class="pulsar-hero__heading">
            {%- if section.settings.heading != blank -%}
              {{ section.settings.heading }}
            {%- else -%}
              TEAM<br>
              PULSAR
            {%- endif -%}
          </h1>
          <p class="pulsar-hero__tagline">
            {{ section.settings.tagline | default: 'Move With Intent.' }}
          </p>
        </div>
      {%- endif -%}
    </div>

    <div class="pulsar-hero__actions">
      <a
        href="{{ section.settings.primary_cta_url | default: '/collections/all' }}"
        class="pulsar-btn pulsar-btn--primary"
      >
        {{- section.settings.primary_cta_label | default: 'Shop Now' -}}
      </a>
      <a
        href="{{ section.settings.secondary_cta_url | default: '/pages/esports' }}"
        class="pulsar-btn pulsar-btn--ghost"
      >
        {{- section.settings.secondary_cta_label | default: 'Our Rosters' -}}
      </a>
    </div>
  </div>

  <div class="pulsar-hero__scroll-indicator" aria-hidden="true">
    <span class="pulsar-hero__scroll-label">Scroll</span>
    <div class="pulsar-hero__scroll-line"></div>
  </div>
</section>

{% stylesheet %}
  .pulsar-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--pulsar-black);
  }

  /* Background video */
  .pulsar-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    will-change: transform;
  }
  .pulsar-hero__bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 110%; /* Extra height absorbs parallax travel */
    object-fit: cover;
    opacity: 0.18;
  }
  .pulsar-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(10, 10, 12, 0.55) 60%,
      rgba(10, 10, 12, 0.95) 100%
    );
  }

  /* Content wrapper */
  .pulsar-hero__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 var(--pulsar-space-lg);
    max-width: 1000px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--pulsar-space-md);
    width: 100%;
  }

  /* Slides container */
  .pulsar-hero__slides {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--pulsar-space-md);
  }

  /* Non-active slides: positioned out of flow */
  .pulsar-hero__slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--pulsar-space-md);
    opacity: 0;
    pointer-events: none;
  }
  /* Active slide: in flow, takes height */
  .pulsar-hero__slide.is-active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
  }

  .pulsar-hero__eyebrow {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray2);
    margin: 0;
  }

  .pulsar-hero__heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(5rem, 16vw, 14rem);
    line-height: 0.88;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
    /* No opacity:0 — mask clip via .pulsar-hero__mask handles initial hide */
  }

  .pulsar-hero__tagline {
    font-family: var(--font-secondary);
    font-size: clamp(1rem, 2vw, 1.5rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pulsar-gray3);
    margin: 0;
  }

  .pulsar-hero__actions {
    display: flex;
    gap: var(--pulsar-space-md);
    margin-top: var(--pulsar-space-sm);
  }

  /* Scroll indicator */
  .pulsar-hero__scroll-indicator {
    position: absolute;
    bottom: var(--pulsar-space-lg);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--pulsar-space-xs);
    z-index: 1;
  }
  .pulsar-hero__scroll-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
  }
  .pulsar-hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--pulsar-gray1), transparent);
    animation: pulsar-scroll-pulse 2s ease-in-out infinite;
  }
  @keyframes pulsar-scroll-pulse {
    0%,
    100% {
      opacity: 0.3;
      transform: scaleY(1);
    }
    50% {
      opacity: 1;
      transform: scaleY(0.6);
    }
  }

  /* Responsive */
  @media (max-width: 767px) {
    .pulsar-hero__heading {
      font-size: clamp(4rem, 20vw, 6rem);
    }
    .pulsar-hero__actions {
      flex-direction: column;
      width: 100%;
      max-width: 300px;
    }
    .pulsar-hero__actions .pulsar-btn {
      text-align: center;
      justify-content: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pulsar Hero",
  "tag": "div",
  "class": "pulsar-section",
  "settings": [
    {
      "type": "header",
      "content": "Single slide (fallback, no blocks)"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "EST. 2020 · NORTH AMERICA"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TEAM PULSAR"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Move With Intent."
    },
    {
      "type": "url",
      "id": "bg_video",
      "label": "Background video URL (optional)"
    },
    {
      "type": "header",
      "content": "Multi-slide settings"
    },
    {
      "type": "range",
      "id": "slide_interval",
      "label": "Slide interval (ms)",
      "min": 1000,
      "max": 9000,
      "step": 500,
      "default": 5000
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Button URL"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Button label",
      "default": "Our Rosters"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow text",
          "default": "EST. 2020 · NORTH AMERICA"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "TEAM PULSAR"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Move With Intent."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pulsar Hero",
      "category": "Pulsar"
    }
  ]
}
{% endschema %}
