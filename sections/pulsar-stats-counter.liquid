<section class="pulsar-stats" id="pulsar-stats-{{ section.id }}">
  <div class="pulsar-stats__inner">
    {%- if section.settings.label != blank -%}
      <p class="pulsar-stats__section-label pulsar-reveal">{{ section.settings.label }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="pulsar-stats__grid pulsar-stats__grid--{{ section.blocks.size }}">
        {%- for block in section.blocks -%}
          {%- if forloop.first == false -%}
            <div class="pulsar-stats__divider" aria-hidden="true"></div>
          {%- endif -%}

          <div class="pulsar-stats__item pulsar-reveal" {{ block.shopify_attributes }}>
            <div class="pulsar-stats__number">
              <span
                data-pulsar-counter="{{ block.settings.value }}"
                data-pulsar-decimals="{{ block.settings.decimals }}"
                {% if block.settings.prefix != blank %}data-pulsar-prefix="{{ block.settings.prefix }}"{% endif %}
                {% if block.settings.suffix != blank %}data-pulsar-suffix="{{ block.settings.suffix }}"{% endif %}
                data-pulsar-duration="{{ block.settings.duration }}"
              >{{ block.settings.prefix }}{{ block.settings.value }}{{ block.settings.suffix }}</span>
            </div>
            {%- if block.settings.label != blank -%}
              <p class="pulsar-stats__label">{{ block.settings.label }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #pulsar-stats-{{ section.id }} {
    background: var(--pulsar-black);
    padding: 88px 0;
    border-top: 1px solid var(--pulsar-dark3);
    border-bottom: 1px solid var(--pulsar-dark3);
  }

  #pulsar-stats-{{ section.id }} .pulsar-stats__inner {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 44px;
  }

  #pulsar-stats-{{ section.id }} .pulsar-stats__section-label {
    margin: 0;
    font-family: var(--font-secondary), sans-serif;
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--pulsar-gray2);
    text-align: center;
  }

  #pulsar-stats-{{ section.id }} .pulsar-stats__grid {
    display: flex;
    align-items: stretch;
    justify-content: center;
    width: 100%;
    gap: 0;
  }

  #pulsar-stats-{{ section.id }} .pulsar-stats__item {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    padding: 0 18px;
    text-align: center;
  }

  #pulsar-stats-{{ section.id }} .pulsar-stats__number {
    font-family: var(--font-display), sans-serif;
    font-size: clamp(58px, 9vw, 140px);
    line-height: 0.92;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    white-space: nowrap;
  }

  #pulsar-stats-{{ section.id }} .pulsar-stats__label {
    margin: 0;
    font-family: var(--font-secondary), sans-serif;
    font-size: 13px;
    line-height: 1.1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--pulsar-gray2);
  }

  #pulsar-stats-{{ section.id }} .pulsar-stats__divider {
    width: 1px;
    min-width: 1px;
    background: var(--pulsar-dark3);
    margin: 0 6px;
  }

  /* Initial hidden state. Animation is owned by gsap.fromTo in pulsar-animations.js.
     No CSS transition here — avoids racing GSAP inline styles when is-visible is added. */
  #pulsar-stats-{{ section.id }} .pulsar-reveal {
    opacity: 0;
    transform: translateY(26px);
  }

  #pulsar-stats-{{ section.id }} .pulsar-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #pulsar-stats-{{ section.id }} .pulsar-stats__section-label { transition-delay: 0.05s; }
  #pulsar-stats-{{ section.id }} .pulsar-stats__item:nth-child(1) { transition-delay: 0.10s; }
  #pulsar-stats-{{ section.id }} .pulsar-stats__item:nth-child(3) { transition-delay: 0.18s; }
  #pulsar-stats-{{ section.id }} .pulsar-stats__item:nth-child(5) { transition-delay: 0.26s; }
  #pulsar-stats-{{ section.id }} .pulsar-stats__item:nth-child(7) { transition-delay: 0.34s; }
  #pulsar-stats-{{ section.id }} .pulsar-stats__item:nth-child(9) { transition-delay: 0.42s; }

  @media (max-width: 989px) {
    #pulsar-stats-{{ section.id }} .pulsar-stats__number {
      font-size: clamp(44px, 8vw, 88px);
    }
  }

  @media (max-width: 767px) {
    #pulsar-stats-{{ section.id }} {
      padding: 64px 0;
    }

    #pulsar-stats-{{ section.id }} .pulsar-stats__inner {
      padding: 0 18px;
      gap: 28px;
    }

    #pulsar-stats-{{ section.id }} .pulsar-stats__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 22px 16px;
    }

    #pulsar-stats-{{ section.id }} .pulsar-stats__divider {
      display: none;
    }

    #pulsar-stats-{{ section.id }} .pulsar-stats__item {
      padding: 0;
      gap: 10px;
    }

    #pulsar-stats-{{ section.id }} .pulsar-stats__number {
      font-size: clamp(40px, 12vw, 64px);
    }

    #pulsar-stats-{{ section.id }} .pulsar-stats__label {
      font-size: 11px;
      letter-spacing: 0.18em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #pulsar-stats-{{ section.id }} .pulsar-reveal {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>

{% schema %}
{
  "name": "Pulsar Stats Counter",
  "tag": "div",
  "class": "pulsar-section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section overline",
      "default": "By the numbers"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "number",
          "id": "value",
          "label": "Number value",
          "default": 0,
          "info": "The target number the counter animates to"
        },
        {
          "type": "text",
          "id": "prefix",
          "label": "Prefix",
          "placeholder": "e.g. $",
          "info": "Shown before the number (e.g. $ for currency)"
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Suffix",
          "placeholder": "e.g. M+ or K+",
          "info": "Shown after the number (e.g. M+, K+, +)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "placeholder": "e.g. Combined Reach"
        },
        {
          "type": "range",
          "id": "decimals",
          "label": "Decimal places",
          "min": 0,
          "max": 2,
          "step": 1,
          "default": 0
        },
        {
          "type": "range",
          "id": "duration",
          "label": "Count duration (ms)",
          "min": 500,
          "max": 4000,
          "step": 100,
          "default": 2000,
          "info": "How long the number counts up in milliseconds"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pulsar Stats Counter",
      "category": "Pulsar",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "value": 2,
            "suffix": "M+",
            "label": "Combined Reach",
            "decimals": 0,
            "duration": 2000
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": 125,
            "prefix": "$",
            "suffix": "K+",
            "label": "Prize Earnings",
            "decimals": 0,
            "duration": 2200
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": 60,
            "suffix": "+",
            "label": "Members",
            "decimals": 0,
            "duration": 1800
          }
        },
        {
          "type": "stat",
          "settings": {
            "value": 5,
            "suffix": "+",
            "label": "Years Active",
            "decimals": 0,
            "duration": 1500
          }
        }
      ]
    }
  ]
}
{% endschema %}
