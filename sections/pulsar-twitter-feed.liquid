<section class="pulsar-twitter">
  <div class="pulsar-twitter__inner">
    <div class="pulsar-twitter__header">
      <p class="pulsar-twitter__overline pulsar-reveal">{{ section.settings.overline | default: 'Latest' }}</p>
      <h2 class="pulsar-twitter__heading pulsar-heading-reveal">
        {{ section.settings.heading | default: 'FOLLOW THE ACTION' }}
      </h2>
      <p class="pulsar-twitter__handle pulsar-reveal">
        <a href="https://x.com/PulsarLLC" target="_blank" rel="noopener noreferrer">@PulsarLLC</a>
      </p>
    </div>

    <div class="pulsar-twitter__embed-wrap pulsar-reveal">
      <div class="pulsar-twitter__tweets">
        <div class="pulsar-twitter__tweet-item">
          <blockquote class="twitter-tweet" data-theme="dark">
            <p lang="en" dir="ltr">Powered by <a href="https://twitter.com/DropMazter?ref_src=twsrc%5Etfw">@DropMazter</a> &amp; <a href="https://twitter.com/OBSBOT_Official?ref_src=twsrc%5Etfw">@OBSBOT_Official</a> <a href="https://t.co/IRhAOYcz3k">pic.twitter.com/IRhAOYcz3k</a></p>&mdash; Team Pulsar (@PulsarLLC) <a href="https://twitter.com/PulsarLLC/status/2021705816437342359?ref_src=twsrc%5Etfw">February 11, 2026</a>
          </blockquote>
        </div>
        
        <div class="pulsar-twitter__tweet-item">
          <blockquote class="twitter-tweet" data-theme="dark">
            <p lang="en" dir="ltr">MATCH DAY ⚡<br><br>Our VALORANT squad hits the server today in the Funhavers Wild//West LAN Qualifier #3.<br><br>🏆 RO32<br>⚔️ vs <a href="https://twitter.com/ShopifyRebels?ref_src=twsrc%5Etfw">@ShopifyRebels</a> Gold<a href="https://twitter.com/PulsarLLC?ref_src=twsrc%5Etfw">@PulsarLLC</a> <a href="https://t.co/ZiZXzEos2c">pic.twitter.com/ZiZXzEos2c</a></p>&mdash; Pulsar Valorant (@PulsarValo) <a href="https://twitter.com/PulsarValo/status/2030344567355068723?ref_src=twsrc%5Etfw">March 7, 2026</a>
          </blockquote>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
(function() {
  var section = document.currentScript.closest('section, div[class*="pulsar-twitter"]') || document.querySelector('.pulsar-twitter');
  if (!section) return;

  var loaded = false;
  var observer = new IntersectionObserver(function(entries) {
    if (entries[0].isIntersecting && !loaded) {
      loaded = true;
      observer.disconnect();
      var s = document.createElement('script');
      s.src = 'https://platform.twitter.com/widgets.js';
      s.async = true;
      s.charset = 'utf-8';
      document.body.appendChild(s);
    }
  }, { rootMargin: '200px' });

  observer.observe(section);
})();
</script>

{% stylesheet %}
  .pulsar-twitter {
    background-color: var(--pulsar-black);
    padding: var(--pulsar-space-xxl) 0;
    border-top: 1px solid var(--pulsar-dark3);
  }
  .pulsar-twitter__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--pulsar-space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-xl);
    align-items: center;
    text-align: center;
  }
  .pulsar-twitter__overline {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    margin: 0 0 var(--pulsar-space-xs);
  }
  .pulsar-twitter__heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
  }
  .pulsar-twitter__handle {
    margin: 0;
  }
  .pulsar-twitter__handle a {
    font-family: var(--font-secondary);
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pulsar-gray2);
    transition: color 0.2s ease;
  }
  .pulsar-twitter__handle a:hover { color: var(--pulsar-white); }

  .pulsar-twitter__embed-wrap {
    width: 100%;
    background-color: transparent;
    border: none;
    border-radius: 0;
    overflow: visible;
    min-height: auto;
  }
  .pulsar-twitter__tweets {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    justify-content: center;
    width: 100%;
    align-items: flex-start;
  }
  .pulsar-twitter__tweet-item {
    flex: 1;
    min-width: 320px;
    max-width: 550px; /* Standard Twitter embed max width */
    width: 100%;
  }
  .pulsar-twitter__tweets .twitter-tweet {
    margin: 0 auto !important;
  }

  @media (max-width: 767px) {
    .pulsar-twitter { padding: var(--pulsar-space-xl) 0; }
    .pulsar-twitter__inner { padding: 0 var(--pulsar-space-md); gap: var(--pulsar-space-lg); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pulsar Twitter Feed",
  "tag": "div",
  "class": "pulsar-section",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "Latest"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FOLLOW THE ACTION"
    },
    {
      "type": "text",
      "id": "twitter_handle",
      "label": "Twitter/X handle (without @)",
      "default": "PulsarLLC"
    },
    {
      "type": "range",
      "id": "tweet_limit",
      "label": "Tweets to show",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    }
  ],
  "presets": [
    {
      "name": "Pulsar Twitter Feed",
      "category": "Pulsar"
    }
  ]
}
{% endschema %}
