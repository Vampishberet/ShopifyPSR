%- liquid
  assign member_names = section.settings.member_names | strip
  assign members = member_names | split: ','
  assign ticker_speed = section.settings.ticker_speed | default: 0.7
  assign pause_on_hover = section.settings.pause_on_hover
-%}

<section
  class="pulsar-ticker-section"
  id="pulsar-ticker-{{section.id}}"
  data-ticker-speed="{{ticker_speed}}"
  data-pause-on-hover="{{pause_on_hover}}"
>
  {%- if section.settings.heading != blank -%}
    <p class="pulsar-ticker-heading">{{ section.settings.heading }}</p>
  {%- endif -%}

  <div class="pulsar-ticker-viewport">
    <div class="pulsar-ticker-track">
      <div class="pulsar-ticker-group">
        {%- for member in members -%}
          {%- assign name = member | strip -%}
          {%- if name != blank -%}
            <span class="pulsar-ticker-item">{{ name }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="pulsar-ticker-group" aria-hidden="true">
        {%- for member in members -%}
          {%- assign name = member | strip -%}
          {%- if name != blank -%}
            <span class="pulsar-ticker-item">{{ name }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #pulsar-ticker-{{ section.id }} {
    background: var(--pulsar-black);
    border-top: 1px solid var(--pulsar-accent-purple-soft);
    border-bottom: 1px solid var(--pulsar-accent-purple-soft);
    padding: 20px 0;
    overflow: hidden;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-heading {
    margin: 0 0 16px;
    text-align: center;
    font-size: 0.65rem;
    font-family: var(--font-body);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-viewport {
    width: 100%;
    overflow: hidden;
    position: relative;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-track {
    display: flex;
    width: max-content;
    will-change: transform;
    transform: translate3d(0, 0, 0);
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-group {
    display: flex;
    flex-shrink: 0;
    min-width: max-content;
    align-items: center;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-item {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    white-space: nowrap;
    font-family: var(--font-secondary);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pulsar-gray3);
    padding: 0 20px;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-item::after {
    content: "✦";
    margin-left: 20px;
    color: var(--pulsar-white);
    font-size: 0.6rem;
  }

  @media screen and (max-width: 767px) {
    #pulsar-ticker-{{ section.id }} .pulsar-ticker-item {
      font-size: 20px;
      padding: 0 16px;
    }

    #pulsar-ticker-{{ section.id }} .pulsar-ticker-item::after {
      margin-left: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #pulsar-ticker-{{ section.id }} .pulsar-ticker-track {
      transform: none !important;
    }
  }
</style>

<script>
  (() => {
    const root = document.getElementById('pulsar-ticker-{{ section.id }}');
    if (!root) return;

    const viewport = root.querySelector('.pulsar-ticker-viewport');
    const track = root.querySelector('.pulsar-ticker-track');
    const baseGroup = track?.querySelector('.pulsar-ticker-group');

    if (!viewport || !track || !baseGroup) return;

    const speed = parseFloat(root.dataset.tickerSpeed) || 0.7;
    const pauseOnHover = root.dataset.pauseOnHover === 'true';
    const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

    let groupWidth = 0;
    let offset = 0;
    let paused = false;
    let frameId = null;
    let lastTime = 0;
    let resizeFrameId = null;

    const clearExtraGroups = () => {
      track.querySelectorAll('[data-ticker-clone="true"]').forEach((clone) => clone.remove());
    };

    const fillViewport = () => {
      clearExtraGroups();

      const viewportWidth = viewport.getBoundingClientRect().width;
      groupWidth = baseGroup.getBoundingClientRect().width;

      if (!groupWidth) return;

      let coveredWidth = track.scrollWidth;

      while (coveredWidth < viewportWidth + groupWidth) {
        const clone = baseGroup.cloneNode(true);
        clone.setAttribute('aria-hidden', 'true');
        clone.dataset.tickerClone = 'true';
        track.appendChild(clone);
        coveredWidth = track.scrollWidth;
      }
    };

    const applyTransform = () => {
      track.style.transform = `translate3d(${offset}px, 0, 0)`;
    };

    const measure = () => {
      fillViewport();

      if (!groupWidth) return;

      offset = -((Math.abs(offset)) % groupWidth);
      applyTransform();
    };

    const stop = () => {
      if (frameId) {
        window.cancelAnimationFrame(frameId);
        frameId = null;
      }
    };

    const tick = (time) => {
      if (!lastTime) lastTime = time;
      const delta = time - lastTime;
      lastTime = time;

      if (!paused && !reducedMotionQuery.matches && groupWidth) {
        offset -= speed * (delta / (1000 / 60));

        if (Math.abs(offset) >= groupWidth) {
          offset += groupWidth;
        }

        applyTransform();
      }

      frameId = window.requestAnimationFrame(tick);
    };

    const start = () => {
      stop();

      if (reducedMotionQuery.matches) {
        track.style.transform = 'none';
        return;
      }

      lastTime = 0;
      frameId = window.requestAnimationFrame(tick);
    };

    const onResize = () => {
      if (resizeFrameId) {
        window.cancelAnimationFrame(resizeFrameId);
      }

      resizeFrameId = window.requestAnimationFrame(() => {
        measure();
      });
    };

    const onMotionChange = () => {
      measure();
      start();
    };

    const onMouseEnter = () => {
      if (pauseOnHover) paused = true;
    };

    const onMouseLeave = () => {
      paused = false;
    };

    const onSectionUnload = (event) => {
      if (event.detail?.sectionId !== '{{ section.id }}') return;

      stop();
      window.removeEventListener('resize', onResize);
      root.removeEventListener('mouseenter', onMouseEnter);
      root.removeEventListener('mouseleave', onMouseLeave);

      if (reducedMotionQuery.removeEventListener) {
        reducedMotionQuery.removeEventListener('change', onMotionChange);
      } else if (reducedMotionQuery.removeListener) {
        reducedMotionQuery.removeListener(onMotionChange);
      }

      document.removeEventListener('shopify:section:unload', onSectionUnload);
    };

    measure();
    start();

    window.addEventListener('resize', onResize);

    if (pauseOnHover) {
      root.addEventListener('mouseenter', onMouseEnter);
      root.addEventListener('mouseleave', onMouseLeave);
    }

    if (reducedMotionQuery.addEventListener) {
      reducedMotionQuery.addEventListener('change', onMotionChange);
    } else if (reducedMotionQuery.addListener) {
      reducedMotionQuery.addListener(onMotionChange);
    }

    document.addEventListener('shopify:section:unload', onSectionUnload);
  })();
</script>

{% schema %}
{
  "name": "Pulsar Member Ribbon",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section label",
      "default": "The people that make it happen"
    },
    {
      "type": "textarea",
      "id": "member_names",
      "label": "Member names",
      "info": "Comma-separated list of member names. Each name scrolls in the ribbon.",
      "default": "PSR Waffle,PSR Vienna,PSR Chimp,PSR Psych,PSR Rev,PSR Dag,PSR Guppy,PSR Blazify,PSR Casper,PSR Cafe,PSR Acsidius,PSR Yum,PSR Nodaz,PSR Light,PSR Zire,PSR Moxi,PSR Ruin,PSR Staryu,PSR Tuhronto,PSR Hapa,PSR Midniii,PSR Channce,PSR Murlo,PSR Rkei,PSR Molly,PSR GazingNicole,PSR Magnus,PSR Ian,PSR Mika,PSR Njuu,PSR Thunder,PSR CeceNuggets,PSR Kaz,PSR Devox,PSR Klamran,PSR Priince,PSR Ryiax,PSR Gards,PSR Sjay,PSR Adrenaleen,PSR Jid,PSR h6rmed,PSR EXR,PSR Korea,PSR Josh,PSR Prioxy,PSR Fancy,PSR Indra,PSR Mei,PSR Volty,PSR Aminz,PSR Rina,PSR Recrim,PSR Teasers,PSR Vampish,PSR Sieon,PSR Mikey,PSR Ache,PSR iGOMA,PSR Gary,PSR Lunar,PSR Twunti,PSR Thibaut,PSR Monster"
    },
    {
      "type": "range",
      "id": "ticker_speed",
      "label": "Ticker speed",
      "min": 0.2,
      "max": 3.0,
      "step": 0.1,
      "default": 0.7,
      "info": "Pixels moved per animation frame. Higher = faster scroll."
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Pulsar Member Ribbon"
    }
  ]
}
{% endschema %}