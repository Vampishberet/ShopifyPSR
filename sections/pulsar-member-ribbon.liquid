{%- liquid
  assign member_names = section.settings.member_names | strip
  assign members = member_names | split: ','
  assign ticker_speed = section.settings.ticker_speed | default: 60
  assign pause_on_hover = section.settings.pause_on_hover
  assign ticker_css_seconds = 12000 | divided_by: ticker_speed | round
-%}

<section
  class="pulsar-ticker-section"
  id="pulsar-ticker-{{ section.id }}"
  data-ticker-speed="{{ ticker_speed }}"
  data-pause-on-hover="{{ pause_on_hover }}"
>
  {%- if section.settings.heading != blank -%}
    <p class="pulsar-ticker-heading">{{ section.settings.heading }}</p>
  {%- endif -%}

  <div class="pulsar-ticker-viewport">
    <div class="pulsar-ticker-track">
      <div class="pulsar-ticker-group">
        {%- for member in members -%}
          {%- assign name = member | strip -%}
          {%- if name != blank -%}
            <span class="pulsar-ticker-item">{{ name }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="pulsar-ticker-group" aria-hidden="true">
        {%- for member in members -%}
          {%- assign name = member | strip -%}
          {%- if name != blank -%}
            <span class="pulsar-ticker-item">{{ name }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #pulsar-ticker-{{ section.id }} {
    background: var(--pulsar-black);
    border-top: 1px solid var(--pulsar-accent-purple-soft);
    border-bottom: 1px solid var(--pulsar-accent-purple-soft);
    padding: 0;
    overflow: hidden;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-heading {
    margin: 0 0 16px;
    text-align: center;
    font-size: 0.65rem;
    font-family: var(--font-body);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-viewport {
    width: 100%;
    overflow: hidden;
    position: relative;
    /* Soft fade at both edges — masks scrolling content without hard clips */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  @keyframes pulsar-ticker-scroll-{{ section.id }} {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* -50% works because the track holds two identical groups (200% total width).
     Moving by -50% of track width = scrolling exactly one group off-screen.
     JS (GSAP) overrides this animation with exact pixel math when available. */
  #pulsar-ticker-{{ section.id }} .pulsar-ticker-track {
    display: flex;
    width: max-content;
    will-change: transform;
    --pulsar-ticker-duration: {{ ticker_css_seconds }}s;
    animation: pulsar-ticker-scroll-{{ section.id }} {{ ticker_css_seconds }}s linear infinite;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-group {
    display: flex;
    flex-shrink: 0;
    min-width: max-content;
    align-items: center;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-item {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    white-space: nowrap;
    font-family: var(--font-secondary);
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pulsar-gray3);
    padding: 14px 24px;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-item::after {
    content: "✦";
    margin-left: 24px;
    color: var(--pulsar-accent-purple2);
    font-size: 0.55rem;
    opacity: 0.7;
  }

  @media screen and (max-width: 767px) {
    #pulsar-ticker-{{ section.id }} .pulsar-ticker-item {
      font-size: 1.25rem;
      padding: 12px 18px;
    }

    #pulsar-ticker-{{ section.id }} .pulsar-ticker-item::after {
      margin-left: 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #pulsar-ticker-{{ section.id }} .pulsar-ticker-track {
      /* Ticker intentionally keeps scrolling under reduced-motion — brand-essential feature.
         Speed is halved via animation-duration override instead of stopping entirely. */
      animation-duration: {{ ticker_css_seconds | times: 3 }}s;
    }
  }
</style>



{% schema %}
{
  "name": "Pulsar Member Ribbon",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section label",
      "default": "The people that make it happen"
    },
    {
      "type": "textarea",
      "id": "member_names",
      "label": "Member names",
      "info": "Comma-separated list of member names. Each name scrolls in the ribbon.",
      "default": "PSR Waffle,PSR Vienna,PSR Chimp,PSR Psych,PSR Rev,PSR Dag,PSR Guppy,PSR Blazify,PSR Casper,PSR Cafe,PSR Acsidius,PSR Yum,PSR Nodaz,PSR Light,PSR Zire,PSR Moxi,PSR Ruin,PSR Staryu,PSR Tuhronto,PSR Hapa,PSR Midniii,PSR Channce,PSR Murlo,PSR Rkei,PSR Molly,PSR GazingNicole,PSR Magnus,PSR Ian,PSR Mika,PSR Njuu,PSR Thunder,PSR CeceNuggets,PSR Kaz,PSR Devox,PSR Klamran,PSR Priince,PSR Ryiax,PSR Gards,PSR Sjay,PSR Adrenaleen,PSR Jid,PSR h6rmed,PSR EXR,PSR Korea,PSR Josh,PSR Prioxy,PSR Fancy,PSR Indra,PSR Mei,PSR Volty,PSR Aminz,PSR Rina,PSR Recrim,PSR Teasers,PSR Vampish,PSR Sieon,PSR Mikey,PSR Ache,PSR iGOMA,PSR Gary,PSR Lunar,PSR Twunti,PSR Thibaut,PSR Monster"
    },
    {
      "type": "range",
      "id": "ticker_speed",
      "label": "Ticker speed (px/s)",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 60,
      "info": "Scroll speed in pixels per second. Higher = faster."
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Pulsar Member Ribbon"
    }
  ]
}
{% endschema %}
