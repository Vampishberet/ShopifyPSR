{%- liquid
  assign member_names = section.settings.member_names | strip
  assign members = member_names | split: ','
  assign ticker_speed = section.settings.ticker_speed | default: 30
  assign pause_on_hover = section.settings.pause_on_hover
-%}

<section
  class="pulsar-ticker-section"
  id="pulsar-ticker-{{ section.id }}"
  style="--ticker-duration: {{ ticker_speed }}s;"
>
  {%- if section.settings.heading != blank -%}
    <p class="pulsar-ticker-heading">{{ section.settings.heading }}</p>
  {%- endif -%}

  <div class="pulsar-ticker-viewport">
    <div class="pulsar-ticker-track{% if pause_on_hover %} pulsar-ticker-track--pause{% endif %}">
      <div class="pulsar-ticker-group" aria-label="Member names">
        {%- for member in members -%}
          {%- assign name = member | strip -%}
          {%- if name != blank -%}
            <span class="pulsar-ticker-item">{{ name }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="pulsar-ticker-group" aria-hidden="true">
        {%- for member in members -%}
          {%- assign name = member | strip -%}
          {%- if name != blank -%}
            <span class="pulsar-ticker-item">{{ name }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #pulsar-ticker-{{ section.id }} {
    background: var(--pulsar-black, #000);
    border-top: 1px solid var(--pulsar-accent-purple-soft, rgba(255,255,255,0.15));
    border-bottom: 1px solid var(--pulsar-accent-purple-soft, rgba(255,255,255,0.15));
    padding: 20px 0;
    overflow: hidden;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-heading {
    margin: 0 0 16px;
    text-align: center;
    font-size: 0.65rem;
    font-family: var(--font-body, sans-serif);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1, #999);
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-viewport {
    width: 100%;
    overflow: hidden;
    position: relative;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-track {
    display: flex;
    width: max-content;
    animation: pulsarTickerScroll-{{ section.id }} var(--ticker-duration) linear infinite;
    will-change: transform;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-track--pause:hover {
    animation-play-state: paused;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-group {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    min-width: max-content;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-item {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    white-space: nowrap;
    font-family: var(--font-secondary, sans-serif);
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pulsar-gray3, #ddd);
    padding: 0 20px;
  }

  #pulsar-ticker-{{ section.id }} .pulsar-ticker-item::after {
    content: "✦";
    margin-left: 20px;
    color: var(--pulsar-white, #fff);
    font-size: 0.6rem;
  }

  @keyframes pulsarTickerScroll-{{ section.id }} {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @media screen and (max-width: 767px) {
    #pulsar-ticker-{{ section.id }} .pulsar-ticker-item {
      font-size: 20px;
      padding: 0 16px;
    }

    #pulsar-ticker-{{ section.id }} .pulsar-ticker-item::after {
      margin-left: 16px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #pulsar-ticker-{{ section.id }} .pulsar-ticker-track {
      animation: none;
      transform: translate3d(0, 0, 0);
    }
  }
</style>

{% schema %}
{
  "name": "Pulsar Member Ribbon",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section label",
      "default": "The people that make it happen"
    },
    {
      "type": "textarea",
      "id": "member_names",
      "label": "Member names",
      "info": "Comma-separated list of member names. Each name scrolls in the ribbon.",
      "default": "PSR Waffle,PSR Vienna,PSR Chimp,PSR Psych,PSR Rev,PSR Dag,PSR Guppy,PSR Blazify,PSR Casper,PSR Cafe,PSR Acsidius,PSR Yum,PSR Nodaz,PSR Light,PSR Zire,PSR Moxi,PSR Ruin,PSR Staryu,PSR Tuhronto,PSR Hapa,PSR Midniii,PSR Channce,PSR Murlo,PSR Rkei,PSR Molly,PSR GazingNicole,PSR Magnus,PSR Ian,PSR Mika,PSR Njuu,PSR Thunder,PSR CeceNuggets,PSR Kaz,PSR Devox,PSR Klamran,PSR Priince,PSR Ryiax,PSR Gards,PSR Sjay,PSR Adrenaleen,PSR Jid,PSR h6rmed,PSR EXR,PSR Korea,PSR Josh,PSR Prioxy,PSR Fancy,PSR Indra,PSR Mei,PSR Volty,PSR Aminz,PSR Rina,PSR Recrim,PSR Teasers,PSR Vampish,PSR Sieon,PSR Mikey,PSR Ache,PSR iGOMA,PSR Gary,PSR Lunar,PSR Twunti,PSR Thibaut,PSR Monster"
    },
    {
      "type": "range",
      "id": "ticker_speed",
      "label": "Ticker duration",
      "min": 10,
      "max": 80,
      "step": 2,
      "default": 30,
      "info": "Lower = faster. This controls how many seconds one full loop takes."
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Pulsar Member Ribbon"
    }
  ]
}
{% endschema %}