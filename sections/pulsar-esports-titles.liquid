<section class="pulsar-esports-titles" data-pulsar-esports>
  <div class="pulsar-esports-titles__inner">

    <!-- Desktop: horizontal tab row (hidden on mobile via CSS) -->
    <div class="pulsar-esports-titles__tabs" role="tablist" aria-label="Esports titles">
      <button
        class="pulsar-esports-titles__tab is-active"
        role="tab"
        aria-selected="true"
        aria-controls="panel-fortnite"
        id="tab-fortnite"
        data-tab="fortnite"
        type="button"
      >
        <span class="pulsar-esports-titles__tab-label">Fortnite</span>
        <span class="pulsar-esports-titles__tab-count">10</span>
      </button>
      <button
        class="pulsar-esports-titles__tab"
        role="tab"
        aria-selected="false"
        aria-controls="panel-valorant"
        id="tab-valorant"
        data-tab="valorant"
        type="button"
      >
        <span class="pulsar-esports-titles__tab-label">Valorant</span>
        <span class="pulsar-esports-titles__tab-count">13</span>
      </button>
      <button
        class="pulsar-esports-titles__tab"
        role="tab"
        aria-selected="false"
        aria-controls="panel-apex"
        id="tab-apex"
        data-tab="apex"
        type="button"
      >
        <span class="pulsar-esports-titles__tab-label">Apex Legends</span>
        <span class="pulsar-esports-titles__tab-count">3</span>
      </button>
    </div>

    <!-- Panels -->
    <div class="pulsar-esports-titles__panels">

      <!-- ==================== FORTNITE ==================== -->
      <div
        class="pulsar-esports-titles__panel is-active"
        id="panel-fortnite"
        role="tabpanel"
        aria-labelledby="tab-fortnite"
        data-panel="fortnite"
      >
        <!-- Mobile accordion header (hidden on desktop) -->
        <button
          class="pulsar-esports-titles__accordion-header is-active"
          data-tab="fortnite"
          type="button"
          aria-expanded="true"
          aria-controls="panel-fortnite-body"
        >
          <span class="pulsar-esports-titles__accordion-label">Fortnite</span>
          <span class="pulsar-esports-titles__accordion-count">10</span>
          <svg class="pulsar-esports-titles__accordion-arrow" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
            <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="pulsar-esports-titles__panel-body" id="panel-fortnite-body">
          <div class="pulsar-esports-titles__panel-header">
            <div class="pulsar-esports-titles__panel-meta">
              <p class="pulsar-esports-titles__panel-game">Fortnite</p>
              <h2 class="pulsar-esports-titles__panel-heading">PSR<br>FORTNITE</h2>
            </div>
            <div class="pulsar-esports-titles__panel-video">
              <div class="pulsar-esports-titles__embed-wrap">
                <iframe
                  src="https://www.youtube.com/embed/MoZfg__UPRo?rel=0&modestbranding=1"
                  title="PSR Fortnite Montage"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          </div>

          <div class="pulsar-esports-titles__roster pulsar-stagger-group">
            {%- assign fn_players = 'Chimp,Gary,Light,Zire,Tuhronto,Channce,Vero,Ryiax,CeceNuggets,GazingNicole' | split: ',' -%}
            {%- for player in fn_players -%}
              <div class="pulsar-player-card pulsar-stagger-item" data-pulsar-player="{{ player }}" data-pulsar-game="Fortnite" role="button" tabindex="0" aria-label="View PSR {{ player }} profile">
                <div class="pulsar-player-card__inner">
                  <span class="pulsar-player-card__game">Fortnite</span>
                  <p class="pulsar-player-card__name">PSR {{ player }}</p>
                  <span class="pulsar-player-card__cta" aria-hidden="true">Connect ↗</span>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>

      <!-- ==================== VALORANT ==================== -->
      <div
        class="pulsar-esports-titles__panel"
        id="panel-valorant"
        role="tabpanel"
        aria-labelledby="tab-valorant"
        data-panel="valorant"
        hidden
      >
        <!-- Mobile accordion header -->
        <button
          class="pulsar-esports-titles__accordion-header"
          data-tab="valorant"
          type="button"
          aria-expanded="false"
          aria-controls="panel-valorant-body"
        >
          <span class="pulsar-esports-titles__accordion-label">Valorant</span>
          <span class="pulsar-esports-titles__accordion-count">13</span>
          <svg class="pulsar-esports-titles__accordion-arrow" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
            <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="pulsar-esports-titles__panel-body" id="panel-valorant-body" hidden>
          <div class="pulsar-esports-titles__panel-header">
            <div class="pulsar-esports-titles__panel-meta">
              <p class="pulsar-esports-titles__panel-game">Valorant</p>
              <h2 class="pulsar-esports-titles__panel-heading">PSR<br>VALORANT</h2>
            </div>
            <div class="pulsar-esports-titles__panel-video">
              <div class="pulsar-esports-titles__embed-wrap">
                <iframe
                  src="https://www.youtube.com/embed/3Po08NzKqlc?rel=0&modestbranding=1"
                  title="PSR Valorant Montage"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          </div>

          <!-- Main roster -->
          <div class="pulsar-esports-titles__roster-section">
            <p class="pulsar-esports-titles__roster-label">Main Roster</p>
            <div class="pulsar-esports-titles__roster pulsar-stagger-group">
              {%- assign val_players = 'Mikey,Moe,Psych,Indra,Klamran,Dag,Ian' | split: ',' -%}
              {%- for player in val_players -%}
                <div class="pulsar-player-card pulsar-stagger-item" data-pulsar-player="{{ player }}" data-pulsar-game="Valorant" role="button" tabindex="0" aria-label="View PSR {{ player }} profile">
                  <div class="pulsar-player-card__inner">
                    <span class="pulsar-player-card__game">Valorant</span>
                    <p class="pulsar-player-card__name">PSR {{ player }}</p>
                    <span class="pulsar-player-card__cta" aria-hidden="true">Connect ↗</span>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>

          <!-- GC sub-section -->
          <div class="pulsar-esports-titles__roster-section pulsar-esports-titles__roster-section--gc">
            <div class="pulsar-esports-titles__gc-header">
              <p class="pulsar-esports-titles__roster-label">Game Changers</p>
              <span class="pulsar-esports-titles__gc-badge">GC</span>
            </div>
            <div class="pulsar-esports-titles__roster pulsar-stagger-group">
              {%- assign gc_players = 'Cafe,Jid,Mei,Rina,Staryu,Vienna' | split: ',' -%}
              {%- for player in gc_players -%}
                <div class="pulsar-player-card pulsar-player-card--gc pulsar-stagger-item" data-pulsar-player="{{ player }}" data-pulsar-game="Valorant GC" role="button" tabindex="0" aria-label="View PSR {{ player }} profile">
                  <div class="pulsar-player-card__inner">
                    <span class="pulsar-player-card__game">Valorant GC</span>
                    <p class="pulsar-player-card__name">PSR {{ player }}</p>
                    <span class="pulsar-player-card__cta" aria-hidden="true">Connect ↗</span>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>
        </div>
      </div>

      <!-- ==================== APEX LEGENDS ==================== -->
      <div
        class="pulsar-esports-titles__panel"
        id="panel-apex"
        role="tabpanel"
        aria-labelledby="tab-apex"
        data-panel="apex"
        hidden
      >
        <!-- Mobile accordion header -->
        <button
          class="pulsar-esports-titles__accordion-header"
          data-tab="apex"
          type="button"
          aria-expanded="false"
          aria-controls="panel-apex-body"
        >
          <span class="pulsar-esports-titles__accordion-label">Apex Legends</span>
          <span class="pulsar-esports-titles__accordion-count">3</span>
          <svg class="pulsar-esports-titles__accordion-arrow" width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
            <path d="M1 1.5L6 6.5L11 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="pulsar-esports-titles__panel-body" id="panel-apex-body" hidden>
          <div class="pulsar-esports-titles__panel-header pulsar-esports-titles__panel-header--no-video">
            <div class="pulsar-esports-titles__panel-meta">
              <p class="pulsar-esports-titles__panel-game">Apex Legends</p>
              <h2 class="pulsar-esports-titles__panel-heading">PSR<br>APEX</h2>
            </div>
          </div>

          <div class="pulsar-esports-titles__roster pulsar-stagger-group">
            {%- assign apex_players = 'Acsidius,zGato,iGOMA' | split: ',' -%}
            {%- for player in apex_players -%}
              <div class="pulsar-player-card pulsar-stagger-item" data-pulsar-player="{{ player }}" data-pulsar-game="Apex Legends" role="button" tabindex="0" aria-label="View PSR {{ player }} profile">
                <div class="pulsar-player-card__inner">
                  <span class="pulsar-player-card__game">Apex Legends</span>
                  <p class="pulsar-player-card__name">PSR {{ player }}</p>
                  <span class="pulsar-player-card__cta" aria-hidden="true">Connect ↗</span>
                </div>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>

    </div><!-- /.pulsar-esports-titles__panels -->
  </div>
</section>

<!-- ── Player Social Drawer ── -->
<div class="pulsar-player-drawer" id="pulsar-player-drawer" role="dialog" aria-modal="true" aria-label="Player profile" hidden>
  <div class="pulsar-player-drawer__backdrop" id="pulsar-drawer-backdrop"></div>
  <div class="pulsar-player-drawer__panel">
    <button class="pulsar-player-drawer__close" aria-label="Close">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M1 1L15 15M15 1L1 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="pulsar-player-drawer__header">
      <p class="pulsar-player-drawer__game" id="pulsar-drawer-game">FORTNITE</p>
      <h3 class="pulsar-player-drawer__name" id="pulsar-drawer-name">PSR PLAYER</h3>
    </div>

    <div class="pulsar-player-drawer__divider"></div>

    <p class="pulsar-player-drawer__label">Find them on our platforms</p>

    <div class="pulsar-player-drawer__socials">
      <a href="https://x.com/PulsarLLC" target="_blank" rel="noopener noreferrer" class="pulsar-player-drawer__social">
        <span class="pulsar-player-drawer__social-platform">Twitter / X</span>
        <span class="pulsar-player-drawer__social-handle">@PulsarLLC</span>
      </a>
      <a href="https://www.twitch.tv/TeamPulsar" target="_blank" rel="noopener noreferrer" class="pulsar-player-drawer__social">
        <span class="pulsar-player-drawer__social-platform">Twitch</span>
        <span class="pulsar-player-drawer__social-handle">TeamPulsar</span>
      </a>
      <a href="https://discord.gg/TeamPulsar" target="_blank" rel="noopener noreferrer" class="pulsar-player-drawer__social">
        <span class="pulsar-player-drawer__social-platform">Discord</span>
        <span class="pulsar-player-drawer__social-handle">discord.gg/TeamPulsar</span>
      </a>
      <a href="https://www.youtube.com/@TeamPulsar" target="_blank" rel="noopener noreferrer" class="pulsar-player-drawer__social">
        <span class="pulsar-player-drawer__social-platform">YouTube</span>
        <span class="pulsar-player-drawer__social-handle">@TeamPulsar</span>
      </a>
      <a href="https://www.instagram.com/pulsarllc/" target="_blank" rel="noopener noreferrer" class="pulsar-player-drawer__social">
        <span class="pulsar-player-drawer__social-platform">Instagram</span>
        <span class="pulsar-player-drawer__social-handle">@pulsarllc</span>
      </a>
    </div>

    <div class="pulsar-player-drawer__footer">
      <p class="pulsar-player-drawer__footer-text">Part of the Pulsar family since day one.</p>
    </div>
  </div>
</div>

{% stylesheet %}
  .pulsar-esports-titles {
    background-color: var(--pulsar-dark1);
    padding: var(--pulsar-space-xxl) 0;
    border-top: 1px solid var(--pulsar-dark3);
  }
  .pulsar-esports-titles__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--pulsar-space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-xl);
  }

  /* === DESKTOP TABS === */
  .pulsar-esports-titles__tabs {
    display: flex;
    align-items: flex-end;
    gap: 0;
    border-bottom: 1px solid var(--pulsar-dark3);
    position: relative;
  }
  .pulsar-esports-titles__tab {
    background: none;
    border: none;
    padding: var(--pulsar-space-md) var(--pulsar-space-lg) var(--pulsar-space-md) 0;
    cursor: pointer;
    display: flex;
    align-items: baseline;
    gap: var(--pulsar-space-xs);
    position: relative;
    transition: opacity 0.2s ease;
  }
  .pulsar-esports-titles__tab::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--pulsar-white);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--pulsar-ease-out);
  }
  .pulsar-esports-titles__tab.is-active::after { transform: scaleX(1); }
  .pulsar-esports-titles__tab-label {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.25rem, 3vw, 2.25rem);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    transition: color 0.2s ease;
  }
  .pulsar-esports-titles__tab.is-active .pulsar-esports-titles__tab-label,
  .pulsar-esports-titles__tab:hover .pulsar-esports-titles__tab-label {
    color: var(--pulsar-white);
  }
  .pulsar-esports-titles__tab-count {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--pulsar-gray1);
    transition: color 0.2s ease;
    padding-bottom: 2px;
  }
  .pulsar-esports-titles__tab.is-active .pulsar-esports-titles__tab-count { color: var(--pulsar-gray2); }

  /* === MOBILE ACCORDION HEADERS === */
  .pulsar-esports-titles__accordion-header {
    display: none; /* Hidden on desktop */
    width: 100%;
    background: none;
    border: none;
    border-bottom: 1px solid var(--pulsar-dark3);
    padding: var(--pulsar-space-md) 0;
    cursor: pointer;
    align-items: center;
    gap: var(--pulsar-space-sm);
    color: var(--pulsar-white);
  }
  .pulsar-esports-titles__accordion-header:focus-visible {
    outline: 2px solid var(--pulsar-white);
    outline-offset: 2px;
  }
  .pulsar-esports-titles__accordion-label {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.25rem, 5vw, 1.75rem);
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: inherit;
    transition: color 0.2s ease;
  }
  .pulsar-esports-titles__accordion-count {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--pulsar-gray1);
  }
  .pulsar-esports-titles__accordion-arrow {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--pulsar-gray1);
    transition: transform 0.3s var(--pulsar-ease-out), color 0.2s ease;
  }
  .pulsar-esports-titles__accordion-header[aria-expanded="true"] .pulsar-esports-titles__accordion-arrow {
    transform: rotate(180deg);
    color: var(--pulsar-white);
  }
  .pulsar-esports-titles__accordion-header.is-active .pulsar-esports-titles__accordion-label {
    color: var(--pulsar-white);
  }

  /* === PANELS === */
  .pulsar-esports-titles__panels { position: relative; }
  .pulsar-esports-titles__panel { display: none; }
  .pulsar-esports-titles__panel.is-active { display: block; }
  .pulsar-esports-titles__panel[hidden] { display: none !important; }
  .pulsar-esports-titles__panel-body[hidden] { display: none !important; }

  /* Panel header — 2-col: meta + video */
  .pulsar-esports-titles__panel-header {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--pulsar-space-xl);
    align-items: start;
    margin-bottom: var(--pulsar-space-xl);
  }
  .pulsar-esports-titles__panel-header--no-video {
    grid-template-columns: 1fr;
  }
  .pulsar-esports-titles__panel-game {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    margin: 0 0 var(--pulsar-space-sm);
  }
  .pulsar-esports-titles__panel-heading {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.88;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
  }

  /* YouTube embed */
  .pulsar-esports-titles__embed-wrap {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    background-color: var(--pulsar-black);
    border: 1px solid var(--pulsar-dark3);
  }
  .pulsar-esports-titles__embed-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* === ROSTER GRID === */
  .pulsar-esports-titles__roster {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1px;
    background-color: var(--pulsar-dark3);
    border: 1px solid var(--pulsar-dark3);
  }

  /* Roster sub-sections (Valorant) */
  .pulsar-esports-titles__roster-section { margin-bottom: var(--pulsar-space-xl); }
  .pulsar-esports-titles__roster-section:last-child { margin-bottom: 0; }
  .pulsar-esports-titles__roster-label {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    margin: 0 0 var(--pulsar-space-md);
  }
  .pulsar-esports-titles__roster-section--gc { padding-top: var(--pulsar-space-xl); border-top: 1px solid var(--pulsar-dark3); }
  .pulsar-esports-titles__gc-header {
    display: flex;
    align-items: center;
    gap: var(--pulsar-space-sm);
    margin-bottom: var(--pulsar-space-md);
  }
  .pulsar-esports-titles__gc-badge {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    background: var(--pulsar-dark3);
    color: var(--pulsar-gray2);
    border: 1px solid var(--pulsar-gray1);
    padding: 0.2em 0.5em;
  }

  /* === PLAYER CARD === */
  .pulsar-player-card {
    background-color: var(--pulsar-dark2);
    transition: background-color 0.2s ease;
  }
  .pulsar-player-card:hover { background-color: var(--pulsar-dark3); }
  .pulsar-player-card__inner {
    padding: var(--pulsar-space-md);
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-xs);
    min-height: 100px;
    justify-content: flex-end;
  }
  .pulsar-player-card__game {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
  }
  .pulsar-player-card__name {
    font-family: var(--font-secondary);
    font-size: clamp(1rem, 2vw, 1.35rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
    line-height: 1.1;
  }
  .pulsar-player-card__role {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pulsar-gray2);
  }
  .pulsar-player-card--gc .pulsar-player-card__inner { border-left: 2px solid var(--pulsar-gray1); }

  /* Player card — clickable state */
  .pulsar-player-card[data-pulsar-player] { cursor: pointer; }
  .pulsar-player-card[data-pulsar-player]:hover { background-color: var(--pulsar-dark3); }
  .pulsar-player-card[data-pulsar-player]:focus-visible {
    outline: 2px solid var(--pulsar-white);
    outline-offset: -2px;
  }
  .pulsar-player-card__cta {
    font-family: var(--font-body);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    margin-top: var(--pulsar-space-xs);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
  }
  .pulsar-player-card[data-pulsar-player]:hover .pulsar-player-card__cta {
    opacity: 1;
    transform: translateY(0);
    color: var(--pulsar-gray3);
  }

  /* ── Player Social Drawer ── */
  .pulsar-player-drawer {
    position: fixed;
    inset: 0;
    z-index: 9000;
    pointer-events: none;
  }
  .pulsar-player-drawer:not([hidden]) { pointer-events: auto; }

  .pulsar-player-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.35s var(--pulsar-ease-out);
  }
  .pulsar-player-drawer.is-open .pulsar-player-drawer__backdrop { opacity: 1; }

  .pulsar-player-drawer__panel {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: min(420px, 90vw);
    background: var(--pulsar-dark2);
    border-left: 1px solid var(--pulsar-dark3);
    padding: var(--pulsar-space-xl) var(--pulsar-space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--pulsar-space-lg);
    transform: translateX(100%);
    transition: transform 0.45s var(--pulsar-ease-out);
    box-shadow: -40px 0 100px rgba(0, 0, 0, 0.6);
    overflow-y: auto;
  }
  .pulsar-player-drawer.is-open .pulsar-player-drawer__panel {
    transform: translateX(0);
  }

  .pulsar-player-drawer__close {
    align-self: flex-end;
    background: none;
    border: 1px solid var(--pulsar-dark3);
    color: var(--pulsar-gray2);
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .pulsar-player-drawer__close:hover { border-color: var(--pulsar-white); color: var(--pulsar-white); }
  .pulsar-player-drawer__close:focus-visible { outline: 2px solid var(--pulsar-white); outline-offset: 2px; }

  .pulsar-player-drawer__game {
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pulsar-gray1);
    margin: 0 0 var(--pulsar-space-xs);
  }
  .pulsar-player-drawer__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 6vw, 3.5rem);
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--pulsar-white);
    margin: 0;
    word-break: break-word;
  }

  .pulsar-player-drawer__divider { height: 1px; background: var(--pulsar-dark3); }

  .pulsar-player-drawer__label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--pulsar-gray2);
    margin: 0;
  }

  .pulsar-player-drawer__socials {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .pulsar-player-drawer__social {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--pulsar-space-md) 0;
    border-bottom: 1px solid var(--pulsar-dark3);
    text-decoration: none;
    transition: opacity 0.18s ease;
  }
  .pulsar-player-drawer__socials .pulsar-player-drawer__social:first-child {
    border-top: 1px solid var(--pulsar-dark3);
  }
  .pulsar-player-drawer__social:hover { opacity: 0.65; }
  .pulsar-player-drawer__social:focus-visible { outline: 2px solid var(--pulsar-white); outline-offset: 2px; }
  .pulsar-player-drawer__social-platform {
    font-family: var(--font-secondary);
    font-size: 1rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pulsar-white);
  }
  .pulsar-player-drawer__social-handle {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--pulsar-gray2);
  }

  .pulsar-player-drawer__footer {
    margin-top: auto;
    padding-top: var(--pulsar-space-lg);
    border-top: 1px solid var(--pulsar-dark3);
  }
  .pulsar-player-drawer__footer-text {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-style: italic;
    color: var(--pulsar-gray1);
    margin: 0;
  }

  /* === RESPONSIVE === */
  @media (max-width: 767px) {
    .pulsar-esports-titles { padding: var(--pulsar-space-xl) 0; }
    .pulsar-esports-titles__inner { padding: 0 var(--pulsar-space-md); gap: 0; }

    /* Hide desktop tab row; show accordion headers instead */
    .pulsar-esports-titles__tabs { display: none; }
    .pulsar-esports-titles__accordion-header { display: flex; }

    /* Panels: always visible so every accordion header remains reachable */
    .pulsar-esports-titles__panel {
      display: block !important;
      border-bottom: 1px solid var(--pulsar-dark3);
    }
    .pulsar-esports-titles__panel[hidden] { display: block !important; }
    .pulsar-esports-titles__panel-body { overflow: hidden; }
    .pulsar-esports-titles__panel.is-active .pulsar-esports-titles__panel-body { display: block; }

    .pulsar-esports-titles__panel-header { grid-template-columns: 1fr; }
    .pulsar-esports-titles__panel-video { order: -1; }
    .pulsar-esports-titles__roster { grid-template-columns: repeat(2, 1fr); }

    /* Panel content gets top padding to clear accordion header */
    .pulsar-esports-titles__panel-header { margin-top: var(--pulsar-space-md); }
  }
{% endstylesheet %}

