<script>
  (function() {
    var tabs = document.querySelectorAll('.pulsar-esports-titles__tab');
    var panels = document.querySelectorAll('.pulsar-esports-titles__panel');

    if (!tabs.length) return;

    function switchTab(targetTab) {
      var targetId = targetTab.dataset.tab;
      var currentPanel = document.querySelector('.pulsar-esports-titles__panel.is-active');
      var nextPanel = document.getElementById('panel-' + targetId);

      if (!nextPanel || currentPanel === nextPanel) return;

      // Update tab states
      tabs.forEach(function(t) {
        t.classList.remove('is-active');
        t.setAttribute('aria-selected', 'false');
      });
      targetTab.classList.add('is-active');
      targetTab.setAttribute('aria-selected', 'true');

      // GSAP crossfade if available, otherwise instant swap
      if (window.gsap) {
        gsap.to(currentPanel, {
          opacity: 0,
          y: -10,
          duration: 0.25,
          ease: 'power2.in',
          onComplete: function() {
            currentPanel.classList.remove('is-active');
            currentPanel.hidden = true;
            nextPanel.hidden = false;
            nextPanel.classList.add('is-active');
            gsap.fromTo(nextPanel,
              { opacity: 0, y: 20 },
              { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }
            );
          }
        });
      } else {
        currentPanel.classList.remove('is-active');
        currentPanel.hidden = true;
        nextPanel.hidden = false;
        nextPanel.classList.add('is-active');
      }
    }

    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() { switchTab(this); });
    });

    // Keyboard navigation
    tabs.forEach(function(tab, i) {
      tab.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowRight') { tabs[(i + 1) % tabs.length].focus(); }
        if (e.key === 'ArrowLeft') { tabs[(i - 1 + tabs.length) % tabs.length].focus(); }
      });
    });
  })();
</script>

<script>
  /* ── Player Social Drawer ── */
  (function () {
    var drawer    = document.getElementById('pulsar-player-drawer');
    var backdrop  = document.getElementById('pulsar-drawer-backdrop');
    var closeBtn  = document.getElementById('pulsar-drawer-close');
    var nameEl    = document.getElementById('pulsar-drawer-name');
    var gameEl    = document.getElementById('pulsar-drawer-game');
    var prevFocus = null;

    if (!drawer) return;

    function openDrawer(playerName, game) {
      nameEl.textContent = 'PSR ' + playerName;
      gameEl.textContent = game.toUpperCase();
      drawer.removeAttribute('hidden');
      /* rAF ensures hidden removal is painted before transition starts */
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          drawer.classList.add('is-open');
        });
      });
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('is-open');
      document.body.style.overflow = '';
      /* Re-hide after transition completes */
      var panel = drawer.querySelector('.pulsar-player-drawer__panel');
      var onEnd = function () {
        drawer.setAttribute('hidden', '');
        panel.removeEventListener('transitionend', onEnd);
        if (prevFocus) { prevFocus.focus(); prevFocus = null; }
      };
      panel.addEventListener('transitionend', onEnd);
    }

    /* Delegate clicks to all player cards */
    document.addEventListener('click', function (e) {
      var card = e.target.closest('[data-pulsar-player]');
      if (!card) return;
      prevFocus = card;
      openDrawer(card.dataset.pulsarPlayer, card.dataset.pulsarGame || '');
    });

    /* Keyboard: Enter / Space on player cards */
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        var card = e.target.closest('[data-pulsar-player]');
        if (card) { e.preventDefault(); prevFocus = card; openDrawer(card.dataset.pulsarPlayer, card.dataset.pulsarGame || ''); }
      }
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) { closeDrawer(); }
    });

    closeBtn.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);
  })();
</script>

