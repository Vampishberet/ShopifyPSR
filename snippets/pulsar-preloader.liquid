{% comment %}
  Pulsar Preloader Snippet
  - Displays on initial page load (skipped after first visit via sessionStorage)
  - Skipped in design mode (Shopify editor) for frictionless section editing
  - Video: 3d animation for preloader.mp4 (547KB)
  - Progress bar animates 0 → 100% via pulsar-animations.js
  - Exit: GSAP slide-up transition revealing hero underneath
{% endcomment %}

{% unless request.design_mode %}
<div id="pulsar-preloader" role="status" aria-label="Loading Team Pulsar" aria-live="polite">
  <p class="pulsar-preloader__label" aria-hidden="true">0%</p>

  <video
    class="pulsar-preloader__video"
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true"
  ></video>

  <div class="pulsar-preloader__progress-track" aria-hidden="true">
    <div class="pulsar-preloader__progress-fill"></div>
  </div>
</div>

<script>
  // Runs synchronously to avoid flash. Only fetches video on first visit.
  (function () {
    var preloader = document.getElementById('pulsar-preloader');
    if (!preloader) return;

    if (sessionStorage.getItem('pulsarPreloaderSeen')) {
      preloader.style.display = 'none';
      return;
    }

    // Only set video src if preloader will actually show — prevents 547KB download on return visits
    var video = preloader.querySelector('.pulsar-preloader__video');
    if (video) {
      video.src = {{ '3d animation for preloader.mp4' | asset_url | json }};
      video.load();
    }
  })();
</script>
{% endunless %}
